{
  "name": "marcus-personal-portfolio",
  "version": "14.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build:prod": "ng build",
    "build:development": "ng build --watch --configuration development",
    "test": "ng test",
    "refresh": "rm -rf package-lock.json && rm -rf node_modules/ && npm i -f",
    "build-docs": "ng build --output-path docs --base-href /web-portfolio/",
    "deploy": "ng add angular-cli-ghpages && ng deploy --base-href=/web-portfolio/"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~14.2.0",
    "@angular/common": "~14.2.0",
    "@angular/compiler": "~14.2.0",
    "@angular/core": "~14.2.0",
    "@angular/forms": "~14.2.0",
    "@angular/platform-browser": "~14.2.0",
    "@angular/platform-browser-dynamic": "~14.2.0",
    "@angular/router": "~14.2.0",
    "ngx-pagination": "^6.0.2",
    "rxjs": "^7.5.0",
    "tslib": "^2.4.0",
    "zone.js": "~0.12.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~14.2.0",
    "@angular/cli": "~14.2.0",
    "@angular/compiler-cli": "~14.2.0",
    "@types/jasmine": "~4.0.0",
    "@types/node": "^20.0.0",
    "angular-cli-ghpages": "~1.0.7",
    "jasmine-core": "~4.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.0.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~4.7.0"
  }
}